        // Reusable Render Functions
        function renderNavigation(items) {
            return items.map(item => 
                `<li>
                    <button data-page="${item.page}" class="page-btn nav-link text-dark hover:text-primary font-medium flex items-center space-x-2">
                        <i class="${item.icon}"></i>
                        <span>${item.label}</span>
                    </button>
                </li>`
            ).join("");
        }

        function renderCareerDomains(items) {
            return items.map(item => 
                `<div class="card-hover bg-white rounded-xl p-6 border border-gray-200">
                    <div class="flex items-center justify-between mb-4">
                        <div class="${item.color} w-12 h-12 rounded-lg flex items-center justify-center">
                            <i class="${item.icon} text-xl"></i>
                        </div>
                        <span class="text-sm font-semibold ${item.growth === 'High' || item.growth === 'Very High' ? 'text-green-600' : 'text-yellow-600'}">
                            ${item.growth} Growth
                        </span>
                    </div>
                    <h4 class="text-xl font-bold text-dark mb-2">${item.name}</h4>
                    <p class="text-gray-600 text-sm mb-3">${item.description}</p>
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-700">${item.jobs} jobs</span>
                        <span class="font-semibold text-primary">${item.salary}</span>
                    </div>
                    <button class="mt-4 text-primary font-medium hover:text-secondary flex items-center space-x-2">
                        <span>Explore ${item.name}</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>`
            ).join("");
        }

        function renderRecommendedCareers(items) {
            return items.map(item => 
                `<div class="p-3 bg-gray-50 rounded-lg">
                    <div class="flex justify-between items-start mb-2">
                        <h5 class="font-semibold text-dark">${item.name}</h5>
                        <span class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full">${item.match} match</span>
                    </div>
                    <div class="text-sm text-gray-600">${item.salary}</div>
                    <button class="mt-2 text-sm text-primary hover:text-secondary font-medium">View Details</button>
                </div>`
            ).join("");
        }

        function renderRecentJobs(items) {
            return items.map(item => 
                `<div class="p-4 border border-gray-200 rounded-lg">
                    <h5 class="font-bold text-dark mb-1">${item.title}</h5>
                    <div class="flex items-center text-sm text-gray-600 mb-2">
                        <i class="fas fa-building mr-2"></i>
                        <span>${item.company}</span>
                        <i class="fas fa-map-marker-alt mx-2"></i>
                        <span>${item.location}</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm px-2 py-1 bg-blue-100 text-blue-700 rounded">${item.type}</span>
                        <span class="font-semibold text-primary">${item.salary}</span>
                    </div>
                </div>`
            ).join("");
        }

        function renderCompanyJobListings(items) {
            return items.map(item => 
                `<div class="p-3 border border-gray-200 rounded-lg">
                    <div class="flex justify-between items-start mb-2">
                        <h5 class="font-semibold text-dark">${item.title}</h5>
                        <span class="text-xs px-2 py-1 ${item.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700'} rounded">
                            ${item.status}
                        </span>
                    </div>
                    <div class="flex justify-between items-center text-sm text-gray-600">
                        <span>${item.applicants} applicants</span>
                        <span>${item.date}</span>
                    </div>
                    <button class="mt-2 w-full py-1 text-sm bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition">
                        View Applicants
                    </button>
                </div>`
            ).join("");
        }

        function renderStats(items) {
            return items.map(item => 
                `<div class="text-center">
                    <div class="text-4xl font-bold text-primary mb-2">${item.value}</div>
                    <div class="text-gray-600">${item.label}</div>
                </div>`
            ).join("");
        }

        function renderFooterLinks(items) {
            return items.map(item => 
                `<li>
                    <a href="${item.href}" class="hover:text-white transition">${item.label}</a>
                </li>`
            ).join("");
        }

        // Page Management
        let currentPage = 'home';

        function showPage(pageId) {
            // Hide all pages
            document.querySelectorAll('.page-content').forEach(page => {
                page.classList.add('hidden');
            });
            
            // Show selected page
            const pageElement = document.getElementById(`${pageId}-page`);
            if (pageElement) {
                pageElement.classList.remove('hidden');
                currentPage = pageId;
                
                // Add animation
                pageElement.classList.add('animate-fade-in');
                setTimeout(() => {
                    pageElement.classList.remove('animate-fade-in');
                }, 500);
            }
        }

        // Page Initialization
        document.addEventListener("DOMContentLoaded", function() {
            // Render all sections
            document.getElementById("nav-list").innerHTML = renderNavigation(navigationItems);
            document.getElementById("mobile-nav-list").innerHTML = renderNavigation(navigationItems);
            document.getElementById("stats-container").innerHTML = renderStats(stats);
            document.getElementById("career-domains-grid").innerHTML = renderCareerDomains(careerDomains);
            document.getElementById("recommended-careers").innerHTML = renderRecommendedCareers(recommendedCareers);
            document.getElementById("recent-jobs").innerHTML = renderRecentJobs(recentJobs);
            document.getElementById("company-job-listings").innerHTML = renderCompanyJobListings(companyJobListings);
            document.getElementById("footer-jobseekers").innerHTML = renderFooterLinks(footerJobseekersLinks);
            document.getElementById("footer-employers").innerHTML = renderFooterLinks(footerEmployersLinks);
            document.getElementById("footer-company").innerHTML = renderFooterLinks(footerCompanyLinks);

            // Page Navigation
            document.querySelectorAll('.page-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const page = this.getAttribute('data-page');
                    showPage(page);
                });
            });

            // Back to home buttons
            document.querySelectorAll('.back-to-home').forEach(btn => {
                btn.addEventListener('click', () => showPage('home'));
            });

            // Logo click
            document.getElementById('logo').addEventListener('click', () => showPage('home'));

            // Mobile Menu Toggle
            const mobileMenuBtn = document.getElementById("mobile-menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            
            mobileMenuBtn.addEventListener("click", function() {
                mobileMenu.classList.toggle("hidden");
                const icon = mobileMenuBtn.querySelector("i");
                if (mobileMenu.classList.contains("hidden")) {
                    icon.className = "fas fa-bars text-xl";
                } else {
                    icon.className = "fas fa-times text-xl";
                }
            });

            // Modal Management
            const loginBtn = document.getElementById("login-btn");
            const signupBtn = document.getElementById("signup-btn");
            const loginModal = document.getElementById("login-modal");
            const signupModal = document.getElementById("signup-modal");
            const closeLoginModal = document.getElementById("close-login-modal");
            const closeSignupModal = document.getElementById("close-signup-modal");
            const switchToSignup = document.getElementById("switch-to-signup");
            const switchToLogin = document.getElementById("switch-to-login");

            function showModal(modal) {
                modal.classList.remove("hidden");
                modal.classList.add("flex");
            }

            function hideModal(modal) {
                modal.classList.add("hidden");
                modal.classList.remove("flex");
            }

            loginBtn.addEventListener("click", () => showModal(loginModal));
            signupBtn.addEventListener("click", () => showModal(signupModal));
            closeLoginModal.addEventListener("click", () => hideModal(loginModal));
            closeSignupModal.addEventListener("click", () => hideModal(signupModal));
            
            switchToSignup.addEventListener("click", () => {
                hideModal(loginModal);
                setTimeout(() => showModal(signupModal), 300);
            });
            
            switchToLogin.addEventListener("click", () => {
                hideModal(signupModal);
                setTimeout(() => showModal(loginModal), 300);
            });

            // Close modals when clicking outside
            [loginModal, signupModal].forEach(modal => {
                modal.addEventListener("click", (e) => {
                    if (e.target === modal) {
                        hideModal(modal);
                    }
                });
            });

            // Form Submissions
            document.getElementById("login-form").addEventListener("submit", function(e) {
                e.preventDefault();
                alert("Login successful!");
                hideModal(loginModal);
            });

            document.getElementById("signup-form").addEventListener("submit", function(e) {
                e.preventDefault();
                alert("Account created successfully!");
                hideModal(signupModal);
            });

            // Get Started Button
            document.getElementById("get-started-btn").addEventListener("click", function() {
                showModal(signupModal);
            });

            // Interactive Progress Bars
            const progressBars = document.querySelectorAll('.progress-bar');
            progressBars.forEach(bar => {
                const width = bar.style.width;
                bar.style.width = '0';
                setTimeout(() => {
                    bar.style.width = width;
                }, 300);
            });

            // CV Upload Interaction
            const cvUploadArea = document.querySelector('.border-dashed');
            if (cvUploadArea) {
                cvUploadArea.addEventListener('click', function() {
                    alert("CV upload dialog would open here");
                });
            }

            // Initialize page
            showPage('home');
        });
